# PostgreSQL
POSTGRES_DB=auth_db
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=change_me_in_production

# Must match the compose service name (auth-db) when running in Docker
DATABASE_URL=postgresql://auth_user:change_me_in_production@auth-db:5432/auth_db

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_32_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
